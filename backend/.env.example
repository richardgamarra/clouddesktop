# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=clouddesktop
DB_USER=clouddesktop_user
DB_PASSWORD=changeme

# Server
PORT=4010
NODE_ENV=production

# JWT
JWT_SECRET=changeme_generate_with_node_-e_"console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_DAYS=30

# App
APP_URL=https://clouddesktop.infoplay.com

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@clouddesktop.infoplay.com
